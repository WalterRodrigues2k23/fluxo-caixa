# Variáveis de ambiente do Fluxo de Caixa
# Copie este arquivo para .env e preencha os valores

# Porta do servidor (padrão: 3000)
PORT=3000

# Secret para JWT (use uma string aleatória forte, mínimo 32 caracteres)
# JWT_SECRET=gere-uma-string-aleatoria-forte-aqui
JWT_SECRET=fc_jwt_secret_2026_CHANGE_ESTAM_SENHA

# Supabase (obtenha em https://supabase.com)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-supabase

# Google OAuth2 - Obtenha em https://console.cloud.google.com
# 1. Crie um projeto
# 2. Configure OAuth consent screen
# 3. Crie credenciais OAuth 2.0 (Client ID e Client Secret)
# 4. Adicione http://localhost:3000/api/auth/google/callback como URI de redirect

GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback